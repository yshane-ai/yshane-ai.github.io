      &lt;img itemprop=&#34;thumbnail&#34; src=&#34;https://yshane-ai.github.io/image/30-2_level.gif&#34; alt=&#34;结果演示&#34;/&gt;
    &lt;/div&gt;
    &lt;a href=&#34;https://yshane-ai.github.io/image/30-2_level.gif&#34; itemprop=&#34;contentUrl&#34;&gt;&lt;/a&gt;
      &lt;figcaption&gt;
          &lt;p&gt;结果演示&lt;/p&gt;
      &lt;/figcaption&gt;
  &lt;/figure&gt;
