&lt;figure  itemprop=&#34;associatedMedia&#34;
  itemscope itemtype=&#34;http://schema.org/ImageObject&#34; &gt;
    &lt;div class=&#34;img&#34;&gt;
      &lt;img itemprop=&#34;thumbnail&#34; src=&#34;https://yshane-ai.github.io/image/30-3_level.gif&#34; alt=&#34;结果演示&#34;/&gt;
    &lt;/div&gt;
    &lt;a href=&#34;https://yshane-ai.github.io/image/30-3_level.gif&#34; itemprop=&#34;contentUrl&#34;&gt;&lt;/a&gt;
